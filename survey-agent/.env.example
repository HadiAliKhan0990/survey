# Same database as the Survey API (Node/Sequelize)
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=survey_db
DB_USERNAME=root
DB_PASSWORD=

# Survey REST API (admin token for CRUD)
SURVEY_API_BASE_URL=http://localhost:3000
SURVEY_API_TOKEN=your_admin_jwt_here

# LLM (optional — keyword fallback works without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Agent server
AGENT_PORT=8000
CORS_ORIGINS=*
