# =============================================================================
# Survey Agent environment
# =============================================================================
#
# DATABASE: Uses the SAME .env as the Survey API (Node project root).
#           Place DB_* in E:\surveyProj\.env — do NOT duplicate unless overriding.
#
#           Required (same as config/database.js / Sequelize):
#             DB_DIALECT, DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD
#
# This file is only for agent-specific settings (optional local overrides).
# =============================================================================

# Survey REST API (admin JWT for CRUD)
SURVEY_API_BASE_URL=http://localhost:3000
SURVEY_API_TOKEN=your_admin_jwt_here

# LLM (optional — keyword fallback works without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Agent server
AGENT_PORT=8000
CORS_ORIGINS=*
